<!DOCTYPE html>
<html>
<head>
    <title>Products</title>
    <style>
        body {
            font-family: Arial;
        }
        .container {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
        }
        .card {
            border: 1px solid #ccc;
            padding: 10px;
            width: 200px;
            text-align: center;
            border-radius: 10px;
        }
        img {
            width: 100%;
            height: 150px;
            object-fit: cover;
        }
    </style>
</head>
<body>

<h1><%=title%></h1>

<div class="container">
    <%for(i=0;i<data.length;i++){%>
    <div class="card">
        <img src="https://example.com/image.jpg" alt="product">
        <h3><%=data[i].name%></h3>
        <p>Category: <%=data[i]['category']%></p>
        <p>Price: $<%=data[i]['price']%></p>
    </div>
    <!-- Add more cards manually or dynamically later -->
    <%}%>
</div>

</body>
</html>