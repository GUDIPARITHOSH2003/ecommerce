<!DOCTYPE html>
<html>
<head>
    <title>Products</title>
    <style>
        body {
            font-family: Arial;
        }
        .container {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
        }
        .card {
            border: 1px solid #ccc;
            padding: 10px;
            width: 200px;
            text-align: center;
            border-radius: 10px;
        }
        img {
            width: 100%;
            height: 150px;
            object-fit: cover;
        }
    </style>
</head>
<body>

<h1><%=title%></h1>

<div class="container">
    <%for(i=0;i<data.length;i++){%>
    <div class="card">
        <img src="<%=data[i].imageurl%>" alt="product">
        <h3><%=data[i].name%></h3>
        <p>Category: <%=data[i]['category']%></p>
        <p>Price: $<%=data[i]['price']%></p>
        <a href="/user/products/<%= data[i]._id %>" class="read-more">
            Read More
        </a>
    </div>
    <!-- Add more cards manually or dynamically later -->
    <%}%>
</div>
<div>
        <h2>Filter Products</h2>
        <form action="/user/filter" method="GET" style="margin-bottom: 20px;">
        
        <!-- Category Filter -->
        <label>Category:</label>
        <select name="category">
            <option value="">All</option>
            <option value="Footwear">Footwear</option>
            <option value="Electronics">Electronics</option>
            <option value="Furniture">Furniture</option>
            <option value="Clothing">Clothing</option>
        </select>

        <!-- Price Filter -->
        <label>Min Price:</label>
        <input type="number" name="lcost" placeholder="Min">

        <label>Max Price:</label>
        <input type="number" name="hcost" placeholder="Max">

        <button type="submit">Apply Filter</button>
        </form>
</div>

</body>
</html>